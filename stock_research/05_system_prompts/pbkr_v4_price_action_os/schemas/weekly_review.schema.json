{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pbkr.local/v4/weekly_review.schema.json",
  "title": "PBKR v4 Weekly Review",
  "description": "Weekly review payload: process adherence, rule violations, modelbook updates, expectancy review, next-week focus. Educational. Not a trade signal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asof",
    "week_id",
    "process_adherence",
    "rule_violations",
    "modelbook_updates",
    "expectancy_review",
    "next_week_focus",
    "signal_safety"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^v4\\.[0-9]+(\\.[0-9]+)?$" },
    "asof": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}([+-][0-9]{2}:[0-9]{2}|Z)$" },
    "week_id": { "type": "string", "pattern": "^wk-[0-9]{4}-W[0-9]{2}$" },
    "process_adherence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boxes_required", "boxes_passed", "adherence_pct"],
      "properties": {
        "boxes_required": { "type": "integer", "minimum": 0 },
        "boxes_passed": { "type": "integer", "minimum": 0 },
        "adherence_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "notes": { "type": "string", "maxLength": 600 }
      }
    },
    "rule_violations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mistake_id", "type", "linked_ticket_id", "corrective_action", "cadence"],
        "properties": {
          "mistake_id": { "type": "string", "pattern": "^mk-[A-Za-z0-9_-]{2,32}$" },
          "type": {
            "enum": [
              "process_skip",
              "tactic_drift",
              "stop_drift",
              "size_overrun",
              "sector_overrun",
              "correlation_overrun",
              "audit_override",
              "gate_override",
              "signal_leak",
              "evidence_gap",
              "time_window_breach"
            ]
          },
          "linked_ticket_id": { "type": "string", "maxLength": 64 },
          "description": { "type": "string", "maxLength": 600 },
          "corrective_action": { "type": "string", "minLength": 1, "maxLength": 600 },
          "cadence": { "enum": ["immediate", "this_week", "structural"] }
        }
      }
    },
    "modelbook_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["modelbook_id", "outcome_class", "lesson"],
        "properties": {
          "modelbook_id": { "type": "string", "pattern": "^mb-[0-9]{8}-[A-Za-z0-9_-]{2,32}$" },
          "outcome_class": {
            "enum": ["winner_leader", "winner_enhancer", "winner_short_term", "loser_stop", "loser_structural", "loser_time", "missed_trade"]
          },
          "lesson": { "type": "string", "minLength": 1, "maxLength": 280 }
        }
      }
    },
    "expectancy_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["closed_trade_count", "hit_rate", "avg_winner_r", "avg_loser_r", "expectancy_r"],
      "properties": {
        "closed_trade_count": { "type": "integer", "minimum": 0 },
        "hit_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "avg_winner_r": { "type": "number" },
        "avg_loser_r": { "type": "number" },
        "expectancy_r": { "type": "number" },
        "trim_into_strength_contribution": { "type": "string", "maxLength": 280 }
      }
    },
    "next_week_focus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["k_adjustment", "carry_over_watchlist_count"],
      "properties": {
        "k_adjustment": { "enum": ["hold", "dial_down", "dial_up"] },
        "carry_over_watchlist_count": { "type": "integer", "minimum": 0 },
        "pending_tactic_ready_count": { "type": "integer", "minimum": 0 },
        "known_event_windows": {
          "type": "array",
          "items": { "type": "string", "maxLength": 280 }
        }
      }
    },
    "signal_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direct_trade_signal", "trade_signal", "automatic_execution_allowed", "human_gate_required"],
      "properties": {
        "direct_trade_signal": { "const": false },
        "trade_signal": { "enum": [null, false] },
        "automatic_execution_allowed": { "const": false },
        "human_gate_required": { "const": true }
      }
    }
  }
}

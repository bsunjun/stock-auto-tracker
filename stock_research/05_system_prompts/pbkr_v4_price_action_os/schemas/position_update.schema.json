{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pbkr.local/v4/position_update.schema.json",
  "title": "PBKR v4 Position Update",
  "description": "A position management action: stop migration, trim, structural exit, or time-stop. Educational. Not a trade signal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asof",
    "position_update_id",
    "linked_ticket_id",
    "name",
    "action_type",
    "action_detail",
    "human_gate",
    "signal_safety"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^v4\\.[0-9]+(\\.[0-9]+)?$" },
    "asof": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}([+-][0-9]{2}:[0-9]{2}|Z)$" },
    "position_update_id": { "type": "string", "pattern": "^pu-[A-Za-z0-9_-]{2,32}$" },
    "linked_ticket_id": { "type": "string", "maxLength": 64 },
    "name": { "type": "string", "minLength": 1, "maxLength": 64 },
    "action_type": {
      "enum": ["stop_migration", "trim_into_strength", "trim_into_weakness", "structural_exit", "time_stop", "risk_stop", "add_on"]
    },
    "action_detail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from_stop_level": { "type": "string", "maxLength": 200 },
        "to_stop_level": { "type": "string", "maxLength": 200 },
        "trim_pct_of_position": { "type": "number", "minimum": 0, "maximum": 100 },
        "exit_trigger": {
          "enum": ["failed_higher_low", "distribution_print", "two_closes_below_ma", "failure_level_break", "group_breakdown", "key_reversal_bar", "time_window_expired", "stop_breached"]
        },
        "trim_trigger": {
          "enum": ["plus_5_partial", "r_multiple_partial", "base_extension_20_25", "climax_session", "first_close_below_ma", "failed_higher_low_test", "adverse_group_signal"]
        },
        "add_on_setup": { "enum": ["LaunchPad", "Gapper", "BaseBreakout", "BreakoutFirstPullback", "ContinuationFlag", "ReversalOfTrend"] },
        "add_on_tactic": {
          "enum": [
            "KeySupportLevelReclaim",
            "ConsolidationPivotBreakout",
            "KeyMovingAveragePullback",
            "KeySupportLevelPullback",
            "OopsReversal",
            "OpeningRangeBreakout",
            "IntradayBaseEntry",
            "HighVolumeClosePivot",
            "AddOnEntry"
          ]
        }
      }
    },
    "rationale": { "type": "string", "minLength": 1, "maxLength": 600 },
    "human_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "result"],
      "properties": {
        "required": { "const": true },
        "result": { "enum": ["pending", "pass", "deny"] },
        "unchecked_items": {
          "type": "array",
          "items": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "signal_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direct_trade_signal", "trade_signal", "automatic_execution_allowed", "human_gate_required"],
      "properties": {
        "direct_trade_signal": { "const": false },
        "trade_signal": { "enum": [null, false] },
        "automatic_execution_allowed": { "const": false },
        "human_gate_required": { "const": true }
      }
    }
  }
}

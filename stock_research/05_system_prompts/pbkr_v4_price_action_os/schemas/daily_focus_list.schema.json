{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pbkr.local/v4/daily_focus_list.schema.json",
  "title": "PBKR v4 Daily Focus List",
  "description": "Output of the Orchestrator. Capped at 5 entries; ideal cardinality 1-3. Educational. Not a trade signal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asof",
    "session_date",
    "focus_list_id",
    "market_cycle_ref",
    "entries",
    "signal_safety"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^v4\\.[0-9]+(\\.[0-9]+)?$" },
    "asof": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}([+-][0-9]{2}:[0-9]{2}|Z)$" },
    "session_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "focus_list_id": { "type": "string", "pattern": "^fl-[0-9]{8}-[A-Za-z0-9_-]{2,32}$" },
    "market_cycle_ref": { "type": "string", "maxLength": 64 },
    "tor_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tor_pct", "k", "tor_ceiling_pct"],
      "properties": {
        "tor_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "k": { "type": "number", "minimum": 0, "maximum": 1 },
        "tor_ceiling_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 0,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "watchlist_item_ref",
          "name",
          "trade_class",
          "edges",
          "setup",
          "entry_tactic",
          "stop_plan_summary",
          "size_plan_summary",
          "sell_plan_summary",
          "thesis",
          "signal_safety"
        ],
        "properties": {
          "entry_id": { "type": "string", "pattern": "^fle-[A-Za-z0-9_-]{2,32}$" },
          "watchlist_item_ref": { "type": "string", "maxLength": 64 },
          "name": { "type": "string", "minLength": 1, "maxLength": 64 },
          "trade_class": { "enum": ["short_term", "swing", "position", "leader_grade_position"] },
          "edges": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["HVE", "HVIPO", "HV1", "RelativeStrength", "NFactor", "GroupMove", "GrowthAcceleration"] }
          },
          "setup": { "enum": ["LaunchPad", "Gapper", "BaseBreakout", "BreakoutFirstPullback", "ContinuationFlag", "ReversalOfTrend"] },
          "entry_tactic": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tactic_id", "trigger_level", "failure_level", "stop_logic", "kr_caveat"],
            "properties": {
              "tactic_id": {
                "enum": [
                  "KeySupportLevelReclaim",
                  "ConsolidationPivotBreakout",
                  "KeyMovingAveragePullback",
                  "KeySupportLevelPullback",
                  "OopsReversal",
                  "OpeningRangeBreakout",
                  "IntradayBaseEntry",
                  "HighVolumeClosePivot",
                  "AddOnEntry"
                ]
              },
              "trigger_level": { "type": "string", "minLength": 1, "maxLength": 200 },
              "failure_level": { "type": "string", "minLength": 1, "maxLength": 200 },
              "stop_logic": { "type": "string", "minLength": 1, "maxLength": 400 },
              "kr_caveat": { "type": "string", "minLength": 1, "maxLength": 400 }
            }
          },
          "stop_plan_summary": { "type": "string", "minLength": 1, "maxLength": 400 },
          "size_plan_summary": { "type": "string", "minLength": 1, "maxLength": 400 },
          "sell_plan_summary": { "type": "string", "minLength": 1, "maxLength": 400 },
          "thesis": { "type": "string", "minLength": 8, "maxLength": 600 },
          "signal_safety": {
            "type": "object",
            "additionalProperties": false,
            "required": ["direct_trade_signal", "trade_signal", "automatic_execution_allowed", "human_gate_required"],
            "properties": {
              "direct_trade_signal": { "const": false },
              "trade_signal": { "enum": [null, false] },
              "automatic_execution_allowed": { "const": false },
              "human_gate_required": { "const": true }
            }
          }
        }
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tier", "source", "date"],
        "properties": {
          "tier": { "type": "integer", "minimum": 1, "maximum": 5 },
          "source": { "type": "string", "minLength": 1, "maxLength": 280 },
          "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "url_or_attribution": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "signal_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direct_trade_signal", "trade_signal", "automatic_execution_allowed", "human_gate_required"],
      "properties": {
        "direct_trade_signal": { "const": false },
        "trade_signal": { "enum": [null, false] },
        "automatic_execution_allowed": { "const": false },
        "human_gate_required": { "const": true }
      }
    }
  }
}

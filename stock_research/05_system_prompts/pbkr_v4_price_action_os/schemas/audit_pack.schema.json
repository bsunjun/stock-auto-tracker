{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pbkr.local/v4/audit_pack.schema.json",
  "title": "PBKR v4 Audit Pack",
  "description": "Auditor output: hard / soft / missing-evidence / forbidden-signal findings per focus list entry. Educational. Not a trade signal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asof",
    "audit_pack_id",
    "audited_focus_list_id",
    "entries",
    "signal_safety"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^v4\\.[0-9]+(\\.[0-9]+)?$" },
    "asof": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}([+-][0-9]{2}:[0-9]{2}|Z)$" },
    "audit_pack_id": { "type": "string", "pattern": "^aud-[0-9]{8}-[A-Za-z0-9_-]{2,32}$" },
    "audited_focus_list_id": { "type": "string", "maxLength": 64 },
    "entries": {
      "type": "array",
      "minItems": 0,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entry_ref", "audit_decision", "findings", "signal_safety"],
        "properties": {
          "entry_ref": { "type": "string", "maxLength": 64 },
          "audit_decision": { "enum": ["pass", "block", "revise_required"] },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["severity", "code", "description"],
              "properties": {
                "severity": { "enum": ["hard_veto", "soft_veto", "missing_evidence", "forbidden_signal"] },
                "code": { "type": "string", "pattern": "^A[0-9]{1,3}$" },
                "description": { "type": "string", "minLength": 1, "maxLength": 600 },
                "suggested_fix": { "type": "string", "maxLength": 600 }
              }
            }
          },
          "counter_thesis": { "type": "string", "maxLength": 600 },
          "risk_notes": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "concentration": { "type": "string", "maxLength": 280 },
              "correlation": { "type": "string", "maxLength": 280 },
              "event_window": { "type": "string", "maxLength": 280 }
            }
          },
          "signal_safety": {
            "type": "object",
            "additionalProperties": false,
            "required": ["direct_trade_signal", "trade_signal", "automatic_execution_allowed", "human_gate_required"],
            "properties": {
              "direct_trade_signal": { "const": false },
              "trade_signal": { "enum": [null, false] },
              "automatic_execution_allowed": { "const": false },
              "human_gate_required": { "const": true }
            }
          }
        }
      }
    },
    "summary_note": { "type": "string", "maxLength": 600 },
    "signal_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direct_trade_signal", "trade_signal", "automatic_execution_allowed", "human_gate_required"],
      "properties": {
        "direct_trade_signal": { "const": false },
        "trade_signal": { "enum": [null, false] },
        "automatic_execution_allowed": { "const": false },
        "human_gate_required": { "const": true }
      }
    }
  }
}

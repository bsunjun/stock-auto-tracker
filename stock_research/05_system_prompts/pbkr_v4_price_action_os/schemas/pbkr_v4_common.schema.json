{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pbkr.local/v4/common.schema.json",
  "title": "PBKR v4 Common Subschema",
  "description": "Common fields embedded in every PBKR v4 payload. Educational. Not a trade signal. Signal-safety invariants are enforced here.",
  "type": "object",
  "definitions": {
    "schema_version": {
      "type": "string",
      "pattern": "^v4\\.[0-9]+(\\.[0-9]+)?$"
    },
    "asof": {
      "type": "string",
      "description": "ISO-8601 timestamp with timezone offset.",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}([+-][0-9]{2}:[0-9]{2}|Z)$"
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tier", "source", "date"],
      "properties": {
        "tier": { "type": "integer", "minimum": 1, "maximum": 5 },
        "source": { "type": "string", "minLength": 1, "maxLength": 280 },
        "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "url_or_attribution": { "type": "string", "maxLength": 500 }
      }
    },
    "source_refs": {
      "type": "array",
      "items": { "$ref": "#/definitions/source_ref" }
    },
    "signal_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direct_trade_signal",
        "trade_signal",
        "automatic_execution_allowed",
        "human_gate_required"
      ],
      "properties": {
        "direct_trade_signal": { "const": false },
        "trade_signal": { "enum": [null, false] },
        "automatic_execution_allowed": { "const": false },
        "human_gate_required": { "const": true }
      }
    },
    "trade_class": {
      "type": "string",
      "enum": ["short_term", "swing", "position", "leader_grade_position"]
    },
    "edge": {
      "type": "string",
      "enum": [
        "HVE",
        "HVIPO",
        "HV1",
        "RelativeStrength",
        "NFactor",
        "GroupMove",
        "GrowthAcceleration"
      ]
    },
    "setup": {
      "type": "string",
      "enum": [
        "LaunchPad",
        "Gapper",
        "BaseBreakout",
        "BreakoutFirstPullback",
        "ContinuationFlag",
        "ReversalOfTrend"
      ]
    },
    "entry_tactic_id": {
      "type": "string",
      "enum": [
        "KeySupportLevelReclaim",
        "ConsolidationPivotBreakout",
        "KeyMovingAveragePullback",
        "KeySupportLevelPullback",
        "OopsReversal",
        "OpeningRangeBreakout",
        "IntradayBaseEntry",
        "HighVolumeClosePivot",
        "AddOnEntry"
      ]
    },
    "stage": {
      "type": "string",
      "enum": ["stage_1", "stage_2", "stage_3", "stage_4"]
    },
    "sub_grade": {
      "type": "string",
      "enum": ["weak", "normal", "strong", "n_a"]
    },
    "kr_designation_status": {
      "type": "string",
      "enum": [
        "clean",
        "investment_attention",
        "investment_warning",
        "investment_risk",
        "administrative_issue",
        "trading_halt",
        "listing_review"
      ]
    },
    "growth_evidence_item": {
      "type": "string",
      "enum": [
        "sales_growth",
        "eps_growth",
        "operating_profit_growth",
        "margin_expansion",
        "turnaround",
        "asp_rise",
        "shipment_growth",
        "backlog_order_growth",
        "consensus_revision_improvement",
        "report_cluster",
        "dart_surprise"
      ]
    }
  }
}

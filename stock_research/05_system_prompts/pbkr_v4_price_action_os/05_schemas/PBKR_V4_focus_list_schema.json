{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pbkr.local/v4/focus_list.schema.json",
  "title": "PBKR v4 Daily Focus List",
  "description": "Output of the Orchestrator (GPT). Capped at 5 entries; ideal cardinality 1-3. Each entry must satisfy ticket_schema constraints. direct_trade_signal must be false. trade_signal must be null. human_gate_required must be true.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "focus_list_id",
    "session_date",
    "mcs_kr",
    "tor_state",
    "entries",
    "disclaimers"
  ],
  "properties": {
    "schema_version": { "const": "v4.1" },
    "focus_list_id": {
      "type": "string",
      "pattern": "^fl-[0-9]{8}-[A-Za-z0-9_-]{2,32}$"
    },
    "session_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "mcs_kr": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage"],
      "properties": {
        "stage": { "enum": ["stage_1", "stage_2", "stage_3", "stage_4"] },
        "sub_grade": { "enum": ["weak", "normal", "strong", "n_a"] },
        "k_multiplier": { "type": "number", "minimum": 0, "maximum": 1 },
        "stage_cap_pct": { "type": "number", "minimum": 0, "maximum": 20 }
      }
    },
    "tor_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tor_pct", "tor_ceiling_pct"],
      "properties": {
        "tor_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "tor_ceiling_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 0,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "ticket_ref",
          "name",
          "trade_class",
          "edge",
          "setup",
          "entry_tactic_id",
          "trigger_level",
          "failure_level",
          "stop_logic_summary",
          "size_plan_summary",
          "sell_plan_summary",
          "thesis",
          "disclaimers"
        ],
        "properties": {
          "entry_id": { "type": "string", "maxLength": 64 },
          "ticket_ref": { "type": "string", "maxLength": 64 },
          "name": { "type": "string", "minLength": 1, "maxLength": 64 },
          "trade_class": {
            "enum": ["short_term", "swing", "position", "leader_grade_position"]
          },
          "edge": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": ["HVE", "HVIPO", "HV1", "RelativeStrength", "NFactor", "GroupMove", "GrowthAcceleration"]
            }
          },
          "setup": {
            "enum": ["LaunchPad", "Gapper", "BaseBreakout", "BreakoutFirstPullback", "ContinuationFlag", "ReversalOfTrend"]
          },
          "entry_tactic_id": {
            "enum": [
              "KeySupportLevelReclaim",
              "ConsolidationPivotBreakout",
              "KeyMovingAveragePullback",
              "KeySupportLevelPullback",
              "OopsReversal",
              "OpeningRangeBreakout",
              "IntradayBaseEntry",
              "HighVolumeClosePivot",
              "AddOnEntry"
            ]
          },
          "trigger_level": { "type": "string", "minLength": 1, "maxLength": 200 },
          "failure_level": { "type": "string", "minLength": 1, "maxLength": 200 },
          "stop_logic_summary": { "type": "string", "minLength": 1, "maxLength": 400 },
          "size_plan_summary": { "type": "string", "minLength": 1, "maxLength": 400 },
          "sell_plan_summary": { "type": "string", "minLength": 1, "maxLength": 400 },
          "thesis": { "type": "string", "minLength": 8, "maxLength": 600 },
          "disclaimers": {
            "type": "object",
            "additionalProperties": false,
            "required": ["direct_trade_signal", "trade_signal", "human_gate_required"],
            "properties": {
              "direct_trade_signal": { "const": false },
              "trade_signal": { "type": "null" },
              "human_gate_required": { "const": true }
            }
          }
        }
      }
    },
    "disclaimers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direct_trade_signal", "trade_signal", "human_gate_required"],
      "properties": {
        "direct_trade_signal": { "const": false },
        "trade_signal": { "type": "null" },
        "human_gate_required": { "const": true }
      }
    }
  }
}

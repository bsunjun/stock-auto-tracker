{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pbkr.local/v4/ticket.schema.json",
  "title": "PBKR v4 Daily Focus Ticket",
  "description": "A human-fillable per-name ticket produced in the morning block. Educational. Not a trade signal. direct_trade_signal must be false. trade_signal must be null. human_gate_required must be true.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ticket_id",
    "session_date",
    "name",
    "trade_class",
    "edge",
    "setup",
    "entry_tactic",
    "stop_plan",
    "size_plan",
    "sell_plan",
    "thesis",
    "counter_thesis",
    "disclaimers"
  ],
  "properties": {
    "schema_version": { "const": "v4.1" },
    "ticket_id": {
      "type": "string",
      "pattern": "^tkt-[0-9]{8}-[A-Za-z0-9_-]{2,32}$"
    },
    "session_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "trade_class": {
      "enum": ["short_term", "swing", "position", "leader_grade_position"]
    },
    "edge": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["HVE", "HVIPO", "HV1", "RelativeStrength", "NFactor", "GroupMove", "GrowthAcceleration"]
      }
    },
    "setup": {
      "enum": ["LaunchPad", "Gapper", "BaseBreakout", "BreakoutFirstPullback", "ContinuationFlag", "ReversalOfTrend"]
    },
    "entry_tactic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tactic_id", "definition", "trigger_level", "failure_level", "stop_logic", "kr_caveat"],
      "properties": {
        "tactic_id": {
          "enum": [
            "KeySupportLevelReclaim",
            "ConsolidationPivotBreakout",
            "KeyMovingAveragePullback",
            "KeySupportLevelPullback",
            "OopsReversal",
            "OpeningRangeBreakout",
            "IntradayBaseEntry",
            "HighVolumeClosePivot",
            "AddOnEntry"
          ]
        },
        "definition": { "type": "string", "minLength": 8, "maxLength": 1000 },
        "trigger_level": { "type": "string", "minLength": 1, "maxLength": 200 },
        "failure_level": { "type": "string", "minLength": 1, "maxLength": 200 },
        "stop_logic": { "type": "string", "minLength": 1, "maxLength": 400 },
        "kr_caveat": { "type": "string", "minLength": 1, "maxLength": 400 }
      }
    },
    "stop_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial_stop_rule", "stop_evaluation_basis"],
      "properties": {
        "initial_stop_rule": { "type": "string", "minLength": 1, "maxLength": 400 },
        "stop_evaluation_basis": { "enum": ["closing", "intraday_hard"] },
        "migration_plan": { "type": "string", "maxLength": 400 }
      }
    },
    "size_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_budget_pct", "stop_distance_pct", "applied_caps", "initial_size_pct"],
      "properties": {
        "risk_budget_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "stop_distance_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "applied_caps": {
          "type": "array",
          "items": {
            "enum": ["risk_budget", "notional_cap", "liquidity_cap", "sector_cap", "stage_cap", "conviction_cap", "setup_quality_cap"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "initial_size_pct": { "type": "number", "minimum": 0, "maximum": 20 },
        "max_size_pct": { "type": "number", "minimum": 0, "maximum": 20 },
        "size_up_rule": { "type": "string", "maxLength": 400 }
      }
    },
    "sell_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trim_into_strength_triggers", "structural_exit_triggers"],
      "properties": {
        "trim_into_strength_triggers": {
          "type": "array",
          "items": {
            "enum": ["plus_5_partial", "r_multiple_partial", "base_extension_20_25", "climax_session"]
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "trim_into_weakness_triggers": {
          "type": "array",
          "items": {
            "enum": ["first_close_below_ma", "failed_higher_low_test", "adverse_group_signal"]
          },
          "uniqueItems": true
        },
        "structural_exit_triggers": {
          "type": "array",
          "items": {
            "enum": ["failed_higher_low", "distribution_print", "two_closes_below_ma", "failure_level_break", "group_breakdown", "key_reversal_bar"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "time_stop_window_sessions": { "type": "integer", "minimum": 1, "maximum": 60 }
      }
    },
    "thesis": { "type": "string", "minLength": 8, "maxLength": 600 },
    "counter_thesis": { "type": "string", "minLength": 8, "maxLength": 600 },
    "linked_audit_id": { "type": "string", "maxLength": 64 },
    "disclaimers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direct_trade_signal", "trade_signal", "human_gate_required"],
      "properties": {
        "direct_trade_signal": { "const": false },
        "trade_signal": { "type": "null" },
        "human_gate_required": { "const": true }
      }
    }
  }
}

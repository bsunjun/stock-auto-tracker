{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pbkr.local/v3_2/macro_politics_technology_flow.schema.json",
  "title": "MacroPoliticsTechnologyFlowPack",
  "description": "Layer 1 — 거시·정치·기술 흐름. 큰 돈의 방향 단서. 매매 신호 아님.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "layer",
    "as_of_kst",
    "items",
    "edge_declared",
    "direct_trade_signal"
  ],
  "properties": {
    "schema_version": { "const": "v3.2" },
    "layer": { "const": "L1_macro_politics_technology_flow" },
    "as_of_kst": { "type": "string", "format": "date-time" },
    "edge_declared": { "type": "string", "minLength": 1 },
    "direct_trade_signal": { "const": false },
    "trade_signal": {
      "description": "null 또는 false 만 허용",
      "anyOf": [
        { "type": "null" },
        { "const": false }
      ]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item_id", "category", "summary", "source_id", "source_name", "buyer_type_impact"],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "category": {
            "type": "string",
            "enum": ["macro", "politics", "technology", "policy", "central_bank", "geopolitics"]
          },
          "summary": { "type": "string", "minLength": 1 },
          "source_id": { "type": "string", "minLength": 1 },
          "source_name": { "type": "string", "minLength": 1 },
          "buyer_type_impact": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["institution", "retail_attention", "fast_money", "foreign", "financial_investment", "pension", "short_cover"]
            }
          },
          "direction_hint": {
            "type": "string",
            "enum": ["risk_on", "risk_off", "neutral", "mixed"]
          }
        }
      }
    }
  }
}

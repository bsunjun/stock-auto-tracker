{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bsunjun/stock-auto-tracker/stock_research/schemas/rolling_memory.schema.json",
  "title": "PBKR Rolling Memory",
  "type": "object",
  "required": ["last_updated", "entries"],
  "additionalProperties": false,
  "properties": {
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the most recent append"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "ticker", "fact_type", "content", "source_key"],
        "additionalProperties": false,
        "properties": {
          "date": { "type": "string", "format": "date" },
          "ticker": { "type": "string", "pattern": "^[A-Z]+:[0-9A-Z]+$" },
          "fact_type": {
            "enum": [
              "thesis",
              "catalyst",
              "risk",
              "audit_finding",
              "estimate_revision",
              "decision",
              "note"
            ]
          },
          "content": { "type": "string" },
          "source_key": { "type": "string" },
          "ttl_days": {
            "type": "integer",
            "minimum": 1,
            "description": "Soft expiry; consumers may downweight after this many days"
          },
          "links": {
            "type": "array",
            "items": { "type": "string", "format": "uri" }
          }
        }
      }
    }
  }
}

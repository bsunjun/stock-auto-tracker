      ]
    },
    {
      "filter_id": "rs_60d_top",
      "expr": "rs_60d_percentile >= 80",
      "n_obs": 8,
      "ic": {
        "ic_5d": 0.78,
        "ic_20d": 0.84,
        "ic_60d": 0.80
      },
      "hit_rate_pos_fwd": 1.0,

# PBKR local path config example
# 실제 값은 로컬 .env에만 넣고 GitHub에는 커밋하지 않는다.

PBKR_ROOT=./
STOCK_RESEARCH_ROOT=/path/to/GoogleDrive/내 드라이브/stock_research
WISE_REPORT_ROOT=/path/to/GoogleDrive/내 드라이브/Chrome에서 저장됨/wisereport
TELEGRAM_ROOT=/path/to/GoogleDrive/내 드라이브/stock_research/01_raw_telegram
TZ=Asia/Seoul
ENV=local
